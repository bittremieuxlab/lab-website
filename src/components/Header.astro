---
import { SITE } from '../config';
import { navLinks } from '../config';

const currentPath = Astro.url.pathname;

const isChildActive = (children: { href: string }[]) =>
  children.some((child) => currentPath === child.href || currentPath.startsWith(child.href));
---

<!-- source: https://getbootstrap.com/docs/5.3/components/navbar/#toggler --><!-- <header class="d-flex justify-content-center py-3"> -->
<nav class="navbar navbar-expand-lg bg-body-tertiary">
  <div class="container">
    <a class="navbar-brand" href="/">{SITE.labName}</a>

    <div class="d-flex align-items-center">
      <a
        href="/search"
        class="btn btn-link text-body d-lg-none me-2"
        title="Search"
        aria-label="Search"
      >
        <i class="bi bi-search"></i>
      </a>
      <button
        class="navbar-toggler border-0"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#navbarTogglerDemo02"
        aria-controls="navbarTogglerDemo02"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <i class="bi bi-list fs-4"></i>
      </button>
    </div>

    <div class="collapse navbar-collapse" id="navbarTogglerDemo02">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        {
          navLinks.map((link) => {
            if (link.children) {
              const isActive = isChildActive(link.children);
              return (
                <li class="nav-item dropdown">
                  <a
                    class={`nav-link dropdown-toggle${isActive ? ' active' : ''}`}
                    href="#"
                    role="button"
                    data-bs-toggle="dropdown"
                    aria-expanded="false"
                  >
                    {link.label}
                  </a>
                  <ul class="dropdown-menu">
                    {link.children.map((child) => {
                      const isChildActive =
                        currentPath === child.href ||
                        (child.href !== '/' && currentPath.startsWith(child.href));
                      return (
                        <li>
                          <a
                            class={`dropdown-item${isChildActive ? ' active' : ''}`}
                            href={child.href}
                          >
                            {child.label}
                          </a>
                        </li>
                      );
                    })}
                  </ul>
                </li>
              );
            } else {
              const isActive =
                currentPath === link.href ||
                (link.href !== '/' && currentPath.startsWith(link.href));
              return (
                <li class="nav-item">
                  <a
                    class={`nav-link${isActive ? ' active' : ''}`}
                    aria-current={isActive ? 'page' : undefined}
                    href={link.href}
                  >
                    {link.label}
                  </a>
                </li>
              );
            }
          })
        }
      </ul>
      <!-- <form class="d-flex" role="search" action="/search" method="get">
        <input
          class="form-control me-2"
          type="search"
          name="q"
          placeholder="Search people & publications…"
          aria-label="Search"
        />
        <button class="btn btn-outline-secondary" type="submit">Search</button>
      </form> -->
      <form
        class="col-12 col-lg-auto mb-3 mb-lg-0 me-lg-3 d-none d-lg-block"
        role="search"
        action="/search"
        method="get"
      >
        <input
          type="search"
          class="form-control"
          name="q"
          placeholder="Search..."
          aria-label="Search"
        />
      </form>
      <div class="dropdown ms-2">
        <button
          id="theme-dropdown-btn"
          type="button"
          class="btn btn-sm btn-outline-secondary dropdown-toggle"
          data-bs-toggle="dropdown"
          aria-expanded="false"
          title="Select display mode"
          aria-label="Select display mode"
        ></button>
        <ul class="dropdown-menu dropdown-menu-end">
          <li>
            <button class="dropdown-item" data-theme-mode="light">
              <i class="bi bi-sun-fill me-2"></i>Light
            </button>
          </li>
          <li>
            <button class="dropdown-item" data-theme-mode="dark">
              <i class="bi bi-moon-fill me-2"></i>Dark
            </button>
          </li>
          <li>
            <button class="dropdown-item" data-theme-mode="colorblind">
              <i class="bi bi-eye me-2"></i>Color blind
            </button>
          </li>
        </ul>
      </div>
    </div>
  </div>
</nav>
<!-- </header> -->
