---
import { SITE, navLinks } from '../config';

const currentPath = Astro.url.pathname;

const isChildActive = (children: { href: string }[]) =>
  children.some((child) => currentPath === child.href || currentPath.startsWith(child.href));
---

<nav class="navbar navbar-expand-lg bg-body-tertiary">
  <div class="container">
    <a class="navbar-brand" href="/">{SITE.labName}</a>

    <!-- Outside collapse: search icon (mobile only) + hamburger.
         Search icon is d-lg-none so it only shows on mobile next to the hamburger.
         On lg+, a second icon inside the collapse handles lg, and the search bar handles xl+. -->
    <div class="d-flex align-items-center gap-1">
      <a href="/search" class="btn btn-link text-body d-lg-none" title="Search" aria-label="Search">
        <i class="bi bi-search"></i>
      </a>
      <button
        class="navbar-toggler border-0"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#navbarNav"
        aria-controls="navbarNav"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <i class="bi bi-list fs-4"></i>
      </button>
    </div>

    <!-- Collapsible section: expanded at lg+, toggled by hamburger below lg -->
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul
        class="navbar-nav me-auto mb-2 mb-lg-0 text-center text-lg-start align-items-center align-items-lg-start"
      >
        {
          navLinks.map((link) => {
            if (link.children) {
              const isActive = isChildActive(link.children);
              return (
                <li class="nav-item dropdown">
                  <a
                    class={`nav-link dropdown-toggle${isActive ? ' active' : ''}`}
                    href="#"
                    role="button"
                    data-bs-toggle="dropdown"
                    aria-expanded="false"
                  >
                    {link.label}
                  </a>
                  <ul class="dropdown-menu">
                    {link.children.map((child) => {
                      const childIsActive =
                        currentPath === child.href ||
                        (child.href !== '/' && currentPath.startsWith(child.href));
                      return (
                        <li>
                          <a
                            class={`dropdown-item${childIsActive ? ' active' : ''}`}
                            href={child.href}
                          >
                            {child.label}
                          </a>
                        </li>
                      );
                    })}
                  </ul>
                </li>
              );
            } else {
              const isActive =
                currentPath === link.href ||
                (link.href !== '/' && currentPath.startsWith(link.href));
              return (
                <li class="nav-item">
                  <a
                    class={`nav-link${isActive ? ' active' : ''}`}
                    aria-current={isActive ? 'page' : undefined}
                    href={link.href}
                  >
                    {link.label}
                  </a>
                </li>
              );
            }
          })
        }
      </ul>

      <!-- Search icon: lg only (mobile icon is outside collapse, search bar handles xl+) -->
      <a
        href="/search"
        class="btn btn-link text-body d-none d-lg-block d-xl-none me-1"
        title="Search"
        aria-label="Search"
      >
        <i class="bi bi-search"></i>
      </a>

      <!-- Search bar: xl+ only -->
      <form
        class="d-none d-xl-block col-xl-auto mb-3 mb-xl-0 me-xl-3"
        role="search"
        action="/search"
        method="get"
      >
        <input
          type="search"
          class="form-control"
          name="q"
          placeholder="Search..."
          aria-label="Search"
        />
      </form>

      <div class="dropdown ms-2 text-end">
        <button
          id="theme-dropdown-btn"
          type="button"
          class="btn btn-sm btn-outline-secondary dropdown-toggle"
          data-bs-toggle="dropdown"
          aria-expanded="false"
          title="Select display mode"
          aria-label="Select display mode"></button>
        <ul class="dropdown-menu dropdown-menu-end">
          <li>
            <button class="dropdown-item" data-theme-mode="light">
              <i class="bi bi-sun-fill me-2"></i>Light
            </button>
          </li>
          <li>
            <button class="dropdown-item" data-theme-mode="dark">
              <i class="bi bi-moon-fill me-2"></i>Dark
            </button>
          </li>
          <li>
            <button class="dropdown-item" data-theme-mode="colorblind">
              <i class="bi bi-eye me-2"></i>Color blind
            </button>
          </li>
        </ul>
      </div>
    </div>
  </div>
</nav>
