---
import { SITE } from '../config';
import '../styles/global.scss';
---

<footer class="footer mt-auto py-3 bg-dark" data-bs-theme="dark">
  <div class="container">
    <div class="d-flex flex-wrap justify-content-between align-items-center py-3 my-4 border-top">
      <span class="text-body-secondary small">© 2026 {SITE.labName}</span>
      <div class="contact-and-social-media-holder">
        <a class="footer-link" href="/contact">Contact</a>
        <div class="footer-social">
          <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
          <a href="https://github.com/bittremieuxlab" aria-label="GitHub" target="_blank" rel="noopener"><i class="bi bi-github"></i></a>
        </div>
      </div>
    </div>
  </div>
</footer>
