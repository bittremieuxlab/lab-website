---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'Open Positions';

const allPositions = await getCollection('positions');

const statusBadge: Record<string, string> = {
  open: 'bg-primary',
  closed: 'bg-secondary',
};
const statusLabel: Record<string, string> = {
  open: 'Open',
  closed: 'Closed',
};
const typeLabel: Record<string, string> = {
  phd: 'PhD',
  postdoc: 'Postdoc',
  internship: 'Internship',
  other: 'Other',
};

async function getContent(entry: (typeof allPositions)[number]) {
  const { Content } = await render(entry);
  return Content;
}
---

<BaseLayout pageTitle={pageTitle}>
  {
    allPositions.length === 0 ? (
      <p class="text-muted">There are currently no open positions in the lab. When new opportunities become available, they will be posted on this page. We encourage interested candidates to check back periodically for future announcements.</p>
    ) : (
      <section class="mb-5">
        {await Promise.all(
          allPositions.map(async (position) => {
            const Content = await getContent(position);
            return (
              <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-start mb-2 flex-wrap gap-2">
                    <h3 class="h5 mb-0">{position.data.title}</h3>
                    <div class="d-flex gap-2">
                      <span class="badge bg-secondary-subtle text-secondary-emphasis">
                        {typeLabel[position.data.type] ?? position.data.type}
                      </span>
                      <span class={`badge ${statusBadge[position.data.status]}`}>
                        {statusLabel[position.data.status]}
                      </span>
                    </div>
                  </div>
                  {(position.data.duration || position.data.location) && (
                    <p class="text-muted small mb-3">
                      {[
                        position.data.duration ? `Full-time · ${position.data.duration}` : null,
                        position.data.location,
                      ]
                        .filter(Boolean)
                        .join(' · ')}
                    </p>
                  )}
                  <div class="small">
                    <Content />
                  </div>
                </div>
              </div>
            );
          })
        )}
      </section>
    )
  }
</BaseLayout>
