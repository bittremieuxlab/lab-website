---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'Thesis';

const allTheses = await getCollection('theses');

const statusBadge: Record<string, string> = {
  available: 'bg-primary',
  ongoing: 'bg-warning text-dark',
  completed: 'bg-secondary',
};
const statusLabel: Record<string, string> = {
  available: 'Available',
  ongoing: 'Ongoing',
  completed: 'Completed',
};
const typeLabel: Record<string, string> = {
  bachelor: 'Bachelor Thesis',
  master: 'Master Thesis',
  'bachelor/master': 'Bachelor / Master Thesis',
  phd: 'PhD Thesis',
};

async function getContent(entry: (typeof allTheses)[number]) {
  const { Content } = await render(entry);
  return Content;
}
---

<BaseLayout pageTitle={pageTitle}>
  {
    allTheses.length === 0 ? (
      <p class="text-muted">There are currently no thesis projects available.</p>
    ) : (
      <div>
        <div class="mb-5">
          {await Promise.all(
            allTheses.map(async (thesis) => {
              const Content = await getContent(thesis);
              return (
                <div class="card border-0 shadow-sm mb-3">
                  <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2 flex-wrap gap-2">
                      <h3 class="h5 mb-0">{thesis.data.title}</h3>
                      <div class="d-flex gap-2">
                        <span class="badge bg-secondary-subtle text-secondary-emphasis">
                          {typeLabel[thesis.data.type] ?? thesis.data.type}
                        </span>
                        <span class={`badge ${statusBadge[thesis.data.status]}`}>
                          {statusLabel[thesis.data.status]}
                        </span>
                      </div>
                    </div>
                    {(thesis.data.student || thesis.data.year) && (
                      <p class="text-muted small mb-2">
                        {[thesis.data.student, thesis.data.year ? `(${thesis.data.year})` : null]
                          .filter(Boolean)
                          .join(' ')}
                      </p>
                    )}
                    {thesis.data.topics.length > 0 && (
                      <p class="text-muted small mb-2">{thesis.data.topics.join(' · ')}</p>
                    )}
                    <div class="small">
                      <Content />
                    </div>
                  </div>
                </div>
              );
            })
          )}
        </div>

        <div class="mb-5">
          <h2 class="h4 border-bottom pb-2 mb-4">How to Apply</h2>
          <p>
            Contact us by email with a brief motivation letter and your transcript of records. We
            will schedule a short meeting to discuss your interests and match you with a suitable
            project. Custom project proposals are also welcome.
          </p>
          <a href="/contact" class="btn btn-primary">
            Contact Us
          </a>
          <a href="/positions" class="btn btn-outline-primary ms-2">
            Open Positions
          </a>
        </div>
      </div>
    )
  }
</BaseLayout>
