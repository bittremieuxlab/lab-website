  title = {Comparing the Applicability of de Facto Population Markers for Spatiotemporal Trend Analysis in Wastewater-Based Epidemiology},
  author = {Quireyns, Maarten and Boogaerts, Tim and Giraldo, Juan Sebastian Piedrahita and Van Wichelen, Natan and Feremans, Len and Benaissati, Ilias and Jonuzi, Q{\"e}ndrim and Verhaegen, Bavo and Van Hoorde, Koenraad and Maloux, Hadrien and Hutse, Veronik and Bittremieux, Wout and Covaci, Adrian and Van Nuijs, Alexander L.N.},
