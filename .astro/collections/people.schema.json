{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email",
      "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
    },
    "role": {
      "type": "string",
      "enum": [
        "PhD Student",
        "Software Engineer",
        "MSc Student",
        "Postdoc",
        "Professor",
        "PI"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "alumni",
        "collaborator"
      ]
    },
    "team": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Mass Spectrometry",
          "Metabolomics"
        ]
      }
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "photo": {
      "type": "string"
    },
    "bio_short": {
      "type": "string"
    },
    "pronouns": {
      "type": "string"
    },
    "affiliation": {
      "type": "string"
    },
    "links": {
      "type": "object",
      "properties": {
        "website": {
          "type": "string",
          "format": "uri"
        },
        "github": {
          "type": "string",
          "format": "uri"
        },
        "scholar": {
          "type": "string",
          "format": "uri"
        },
        "orcid": {
          "type": "string"
        },
        "linkedin": {
          "type": "string",
          "format": "uri"
        }
      },
      "additionalProperties": false
    },
    "selected_publications": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "awards": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "education": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "email",
    "role",
    "status",
    "team",
    "tags"
  ],
  "additionalProperties": false
}