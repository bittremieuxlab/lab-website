{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "phd",
        "postdoc",
        "internship",
        "other"
      ]
    },
    "status": {
      "default": "open",
      "type": "string",
      "enum": [
        "open",
        "closed"
      ]
    },
    "duration": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "type",
    "status"
  ],
  "additionalProperties": false
}